# ═══════════════════════════════════════════════════════════════════
# ANMA Regalos — Environment variables
# ═══════════════════════════════════════════════════════════════════
# Copiá este archivo como `.env` (local) o pegalos en Vercel Dashboard
# → Settings → Environment Variables (producción)
#
# El .env NUNCA se commitea (está en .gitignore). El .env.example SÍ.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase (cliente — expuesto al browser, OK por RLS) ───────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# ── Supabase (server-only — JAMÁS exponer al cliente) ──────────────
# Usado por las Vercel functions /api/* para bypass RLS cuando reciben webhooks
# Sacalo de: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── Mercado Pago (server-only) ─────────────────────────────────────
# Access Token de tu app MP — empezar con TEST-, cambiar a APP_USR- en prod
# Sacalo de: mercadopago.com.ar/developers → tu app → Credenciales
MP_ACCESS_TOKEN=TEST-881124199003012-060823-...

# Opcional: secret del webhook para validar firma (lo da MP al crear el webhook)
MP_WEBHOOK_SECRET=

# ── App config (server-only) ───────────────────────────────────────
# URL base de tu app — la usan las Vercel functions para construir back_urls de MP
APP_BASE_URL=https://anma-host.vercel.app
